{
  "pluginAlias": "WhiskerTing",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "Ting"
      },
      "username": {
        "title": "Whisker Email",
        "type": "string",
        "format": "email",
        "description": "Preferred. The email address used to sign in to the Ting app."
      },
      "password": {
        "title": "Whisker Password",
        "type": "string",
        "format": "password",
        "x-schema-form": {
          "type": "password"
        },
        "writeOnly": true,
        "description": "Preferred. The password used to sign in to the Ting app."
      },
      "pollInterval": {
        "title": "Poll Interval Seconds",
        "type": "integer",
        "default": 60,
        "minimum": 30
      }
    }
  }
}
